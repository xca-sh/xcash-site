import Layout from '../../../../layouts/Layout.astro'
---

<Layout
  lang="en"
  noDefaultSchemas={true}
  title="BTCPay Server vs Xcash: Which Self-Hosted Payment Gateway Fits Your Business? | Xcash"
  description="BTCPay Server vs Xcash comparison — the two leading open-source self-hosted crypto payment gateways. Bitcoin-only shops should pick BTCPay. Multi-chain businesses need Xcash. Compare setup, features, supported chains, and costs."
  canonical="https://xca.sh/en/blog/btcpayserver-vs-xcash-which-self-hosted-payment-gateway-fits-your-business/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://xca.sh/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://xca.sh/en/blog/" },
        { "@type": "ListItem", "position": 3, "name": "BTCPay Server vs Xcash: Which Self-Hosted Payment Gateway Fits Your Business?" }
      ]
    })} />
