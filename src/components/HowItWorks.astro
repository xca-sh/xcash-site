---
import zh from '../i18n/zh.json'

const steps = zh.howItWorks.steps
const stepCodes = [
  'git clone https://github.com/xca-sh/xcash.git\ncd xcash && ./scripts/init_env.sh\ndocker compose up -d',
  '# 默认管理员账号\nusername: admin\npassword: Admin@123456\n# 登录 → 绑定 OTP → 链管理填写 RPC',
  'POST /v1/invoice\n{\n  "out_no": "order-20240101-001",\n  "title": "Premium Plan",\n  "currency": "USD",\n  "amount": "29.99"\n}',
]
// Download, Settings, Rocket SVG paths
const iconPaths = [
  '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>',
  '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
  '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
]
---

<section id="how-it-works" class="relative py-24 md:py-32 bg-surface-alt">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <p data-i18n="howItWorks.label" class="text-primary text-sm font-medium tracking-wide uppercase mb-3 animate-on-scroll">
        {zh.howItWorks.label}
      </p>
      <h2 data-i18n="howItWorks.title" class="text-3xl md:text-4xl font-bold text-text-primary tracking-tight animate-on-scroll">
        {zh.howItWorks.title}
      </h2>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      {steps.map((step, i) => {
        const stepNum = String(i + 1).padStart(2, '0')
        const lines = stepCodes[i].split('\n')
        return (
          <div class="relative animate-on-scroll" style={`--delay: ${i * 150}ms`}>
            {i < 2 && (
              <div class="hidden lg:block absolute top-14 left-[calc(100%_-_8px)] w-[calc(100%_-_48px)] h-px">
                <div class="w-full h-full bg-gradient-to-r from-border to-transparent" />
              </div>
            )}
            <div class="relative p-8 rounded-2xl border border-border bg-card hover:shadow-lg hover:shadow-gray-100 transition-all duration-300">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-primary-light flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                    <Fragment set:html={iconPaths[i]} />
                  </svg>
                </div>
                <span class="text-5xl font-black text-gray-100">{stepNum}</span>
              </div>
              <h3 class="text-xl font-bold text-text-primary mb-3" data-i18n={`howItWorks.steps.${i}.title`}>{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-6" data-i18n={`howItWorks.steps.${i}.description`}>{step.description}</p>
              <div class="rounded-lg bg-code-bg p-4 font-mono text-xs leading-relaxed overflow-x-auto">
                {lines.map((line) => (
                  <div class={line.startsWith('#') ? 'text-gray-500' : 'text-green-400'}>
                    {line.startsWith('#') ? line : <><span class="text-gray-500 select-none">$ </span>{line}</>}
                  </div>
                ))}
              </div>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>
