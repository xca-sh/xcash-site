---
import zh from '../i18n/zh.json'

const footerSections = [
  {
    titleKey: 'footer.product',
    title: zh.footer.product,
    links: [
      { labelKey: 'footer.links.features', label: zh.footer.links.features, href: '#features' },
      { labelKey: 'footer.links.pricing', label: zh.footer.links.pricing, href: '#pricing' },
      { labelKey: 'footer.links.security', label: zh.footer.links.security, href: '#security' },
      { labelKey: 'footer.links.changelog', label: zh.footer.links.changelog, href: 'https://github.com/xca-sh/xcash/releases' },
    ],
  },
  {
    titleKey: 'footer.developers',
    title: zh.footer.developers,
    links: [
      { labelKey: 'footer.links.documentation', label: zh.footer.links.documentation, href: 'https://docs.xca.sh' },
      { labelKey: 'footer.links.apiReference', label: zh.footer.links.apiReference, href: 'https://github.com/xca-sh/xcash/blob/main/API.md' },
      { labelKey: 'footer.links.github', label: zh.footer.links.github, href: 'https://github.com/xca-sh/xcash' },
      { labelKey: 'footer.links.selfHosting', label: zh.footer.links.selfHosting, href: 'https://docs.xca.sh/deploy' },
    ],
  },
  {
    titleKey: 'footer.company',
    title: zh.footer.company,
    links: [
      { labelKey: 'footer.links.about', label: zh.footer.links.about, href: '#' },
      { labelKey: 'footer.links.blog', label: zh.footer.links.blog, href: '#' },
      { labelKey: 'footer.links.contact', label: zh.footer.links.contact, href: 'mailto:hello@xca.sh' },
      { labelKey: 'footer.links.privacy', label: zh.footer.links.privacy, href: '#' },
    ],
  },
]

const currentYear = new Date().getFullYear()
---

<footer class="border-t border-border bg-surface-alt">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <img src="/logo.svg" alt="Xcash" class="w-8 h-8" />
          <span class="text-text-primary font-semibold text-lg tracking-tight">Xcash</span>
        </div>
        <p data-i18n="footer.description" class="text-text-muted text-sm leading-relaxed mb-6 max-w-[240px]">
          {zh.footer.description}
        </p>
        <div class="flex gap-3">
          <a href="https://github.com/xca-sh/xcash" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg border border-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-gray-300 transition-colors duration-200 cursor-pointer" aria-label="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg border border-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-gray-300 transition-colors duration-200 cursor-pointer" aria-label="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg border border-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-gray-300 transition-colors duration-200 cursor-pointer" aria-label="Discord">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
          </a>
        </div>
      </div>

      {footerSections.map((section) => (
        <div>
          <h4 class="text-text-primary text-sm font-semibold mb-4" data-i18n={section.titleKey}>{section.title}</h4>
          <ul class="flex flex-col gap-2.5">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="text-text-muted hover:text-text-primary text-sm transition-colors duration-200 cursor-pointer"
                  data-i18n={link.labelKey}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-muted text-xs">
        &copy; {currentYear} <span data-i18n="footer.copyright">{zh.footer.copyright}</span>
      </p>
      <p class="text-text-muted text-xs" data-i18n="footer.slogan">
        {zh.footer.slogan}
      </p>
    </div>
  </div>
</footer>
