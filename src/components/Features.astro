---
import zh from '../i18n/zh.json'

const items = zh.features.items
const featureStyles = [
  { bg: 'bg-blue-50', color: 'text-blue-500' },
  { bg: 'bg-emerald-50', color: 'text-emerald-500' },
  { bg: 'bg-violet-50', color: 'text-violet-500' },
  { bg: 'bg-orange-50', color: 'text-orange-500' },
  { bg: 'bg-cyan-50', color: 'text-cyan-500' },
  { bg: 'bg-rose-50', color: 'text-rose-500' },
  { bg: 'bg-slate-50', color: 'text-slate-500' },
  { bg: 'bg-amber-50', color: 'text-amber-500' },
]
// SVG paths from lucide icons: CreditCard, ArrowDownToLine, ArrowUpFromLine, Layers, Webhook, Shield, Server, Coins
const iconPaths = [
  // CreditCard
  '<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>',
  // ArrowDownToLine
  '<path d="M12 17V3"/><path d="m6 11 6 6 6-6"/><line x1="19" x2="5" y1="21" y2="21"/>',
  // ArrowUpFromLine
  '<path d="m18 9-6-6-6 6"/><path d="M12 3v14"/><line x1="5" x2="19" y1="21" y2="21"/>',
  // Layers
  '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  // Webhook
  '<path d="M18 16.98h1a2 2 0 0 0 1.85-2.77l-3.53-8.5A2 2 0 0 0 15.46 4h0a2 2 0 0 0-1.86 1.27"/><path d="m13.5 11-2.64 6.35A2 2 0 0 1 9 18.98h0a2 2 0 0 1-1.86-1.27L3.5 9.2a2 2 0 0 1 1.85-2.77H7"/><circle cx="12" cy="7" r="1"/>',
  // Shield
  '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  // Server
  '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  // Coins
  '<circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/>',
]
---

<section id="features" class="relative py-24 md:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <p data-i18n="features.label" class="text-primary text-sm font-medium tracking-wide uppercase mb-3 animate-on-scroll">
        {zh.features.label}
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary tracking-tight animate-on-scroll">
        <span data-i18n="features.title">{zh.features.title}</span>
        <br class="hidden sm:block" />
        <span data-i18n="features.titleSuffix">{zh.features.titleSuffix}</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {items.map((item, i) => (
        <div
          class="animate-on-scroll group relative p-6 rounded-2xl border border-border bg-card hover:shadow-lg hover:shadow-gray-100 transition-all duration-300"
          style={`--delay: ${i * 60}ms`}
        >
          <div class={`w-10 h-10 rounded-xl ${featureStyles[i].bg} flex items-center justify-center mb-4`}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20" height="20" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"
              class={featureStyles[i].color}
            >
              <Fragment set:html={iconPaths[i]} />
            </svg>
          </div>
          <h3 class="text-text-primary font-semibold text-lg mb-2" data-i18n={`features.items.${i}.title`}>{item.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed" data-i18n={`features.items.${i}.description`}>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
